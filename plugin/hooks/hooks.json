{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project --quiet python ${CLAUDE_PLUGIN_ROOT}/scripts/continuous_save_prime.py",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project --quiet python ${CLAUDE_PLUGIN_ROOT}/scripts/auto_read.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*set_project_memory|.*update_project_memory",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project --quiet python ${CLAUDE_PLUGIN_ROOT}/scripts/block_subagent_writes.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*set_project_memory|.*update_project_memory",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project --quiet python ${CLAUDE_PLUGIN_ROOT}/scripts/check_dream.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
