{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/auto-read.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*set_project_memory|.*update_project_memory",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/check-dream.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "If you learned something non-obvious during this turn that would help in future sessions (architecture decisions, gotchas, conventions, key insights), save it to project memory now using update_project_memory or set_project_memory. If nothing worth persisting — approve stop.",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
